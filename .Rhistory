library(MATrstars)
set.seed(1)
df <- data.frame(
x = c(rnorm(50, 0, 1), 15, -12),           # dos outliers extremos
y = c(rnorm(52, 0, 1))
)
# Univariante:
explora_outliers(df, x, accion = "documentar")
# Multivariante:
explora_outliers(df, c(x, y), accion = "documentar")
# Forzar escala lineal para comparar:
explora_outliers(df, x, accion = "documentar", escala = "lineal")
# Todo el df (2 columnas → multivariante):
explora_outliers(df, accion = "documentar")
# Con no-métricas — debe avisar y no ejecutar:
df$grupo <- rep(c("A", "B"), 26)
explora_outliers(df, c(x, y, grupo), accion = "documentar")

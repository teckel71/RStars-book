# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# Test de presenta_logit() вЂ” funciГіn del paquete MATrstars
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
#
# Este script verifica el correcto funcionamiento de presenta_logit() usando
# dos escenarios: (1) con el dataset mtcars (rГЎpido, sin archivos externos)
# y (2) con el dataset licencias_100.xlsx del capГ­tulo 10 del libro R-Stars.
#
# Ejecutar en RStudio con un documento HTML abierto, o dentro de un chunk
# de un Rmd, para que las tablas kable_rstars() se rendericen correctamente.
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
rm(list = ls())
# в”Ђв”Ђ 0. Cargar paquete в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if (!requireNamespace("MATrstars", quietly = TRUE)) {
if (!requireNamespace("remotes", quietly = TRUE)) install.packages("remotes")
remotes::install_github("teckel71/MATrstars")
}
library(MATrstars)
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# TEST 1: mtcars (transmisiГіn automГЎtica / manual)
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
cat("\nв•ђв•ђв•ђв•ђв•ђв•ђ TEST 1: mtcars в•ђв•ђв•ђв•ђв•ђв•ђ\n\n")
# Modelo: ВїquГ© variables predicen la transmisiГіn manual (am = 1)?
modelo_mt <- glm(am ~ wt + hp + disp, data = mtcars,
family = binomial(link = "logit"))
# --- Sin matriz de confusiГіn ---
salida1 <- presenta_logit(modelo_mt)
cat("Elementos devueltos (sin datos):", paste(names(salida1), collapse = ", "), "\n")
salida1$coef    # Tabla 1: coeficientes
salida1$gof     # Tabla 2: bondad del ajuste
salida1$or      # Tabla 3: odd ratios
# --- Con matriz de confusiГіn ---
salida1b <- presenta_logit(modelo_mt, datos = mtcars)
cat("Elementos devueltos (con datos):", paste(names(salida1b), collapse = ", "), "\n")
salida1b$conf   # Tabla 4: matriz de confusiГіn
# --- Con captions personalizados ---
salida1c <- presenta_logit(modelo_mt,
datos    = mtcars,
captions = c("Coeficientes del logit",
"Ajuste global",
"Odd ratios",
"PredicciГіn in-sample"),
font_size = 12)
salida1c$coef
salida1c$gof
salida1c$or
salida1c$conf
cat("\nв•ђв•ђв•ђв•ђв•ђв•ђ TEST 2: licencias_100 в•ђв•ђв•ђв•ђв•ђв•ђ\n\n")
library(readxl)
# Cargar datos (ajustar la ruta si es necesario)
LICENCIAS <- read_excel("licencias_100.xlsx", sheet = "Datos")
# Convertir factores
LICENCIAS$EFLO     <- factor(LICENCIAS$EFLO,
levels = c("ANTIGUA", "MADURA", "RENOVADA"))
LICENCIAS$LICENCIA <- factor(LICENCIAS$LICENCIA)
# Verificar estructura
str(LICENCIAS)
summary(LICENCIAS)
# ParticiГіn en muestra de estimaciГіn (80) y muestra de test (20)
set.seed(2210)
idx <- sample(1:nrow(LICENCIAS), 80)
ESTIMA <- LICENCIAS[idx, ]
TEST   <- LICENCIAS[-idx, ]
cat("Muestra de estimaciГіn:", nrow(ESTIMA), "casos\n")
cat("Muestra de test:", nrow(TEST), "casos\n")
cat("Licencias en ESTIMA:", table(ESTIMA$LICENCIA), "\n")
cat("Licencias en TEST:", table(TEST$LICENCIA), "\n")
modelo <- glm(LICENCIA ~ SOLVENCIA + IPUNT + TINCID + IFIDE +
FLOTA + RUTAS + EXPERIENCIA + EFLO,
data = ESTIMA, family = binomial(link = "logit"))
summary(modelo)
# PresentaciГіn con presenta_logit()
salida <- presenta_logit(modelo, datos = ESTIMA)
salida$coef    # Tabla 1: ВїquГ© variables son significativas?
salida$gof     # Tabla 2: ВїcГіmo de bueno es el ajuste?
salida$or      # Tabla 3: ВїcuГЎnto cambia la ventaja por unidad?
salida$conf    # Tabla 4: ВїcuГЎntas clasifica bien (in-sample)?
salida_test <- presenta_logit(modelo, datos = TEST,
captions = c("Modelo Logit Binomial",
"Bondad del ajuste",
"Odd ratios",
"Matriz de confusiГіn (TEST)"))
salida_test$conf   # ВїCГіmo clasifica sobre datos no vistos?
modelo_step <- step(modelo, trace = 1)
summary(modelo_step)
salida_step <- presenta_logit(modelo_step, datos = ESTIMA,
captions = c("Modelo reducido (step)",
"Bondad del ajuste",
"Odd ratios",
"Matriz de confusiГіn"))
salida_step$coef
salida_step$gof
salida_step$or
salida_step$conf
# PredicciГіn del modelo reducido sobre test
salida_step_test <- presenta_logit(modelo_step, datos = TEST,
captions = c("Modelo reducido",
"Bondad del ajuste",
"Odd ratios",
"ConfusiГіn (TEST)"))
salida_step_test$conf
# Crear escenarios ficticios: tres compaГ±Г­as con perfiles distintos
escenarios <- data.frame(
SOLVENCIA   = c(200, 150, 180),
IPUNT       = c(75,  45,  60),
TINCID      = c(3,   12,   7),
IFIDE       = c(45,  30,  40),
FLOTA       = c(20,  10,  25),
RUTAS       = c(500, 200, 400),
EXPERIENCIA = c(15,   3,   8),
EFLO        = factor(c("RENOVADA", "ANTIGUA", "MADURA"),
levels = c("ANTIGUA", "MADURA", "RENOVADA"))
)
# Probabilidades estimadas
probabilidades <- predict(modelo, newdata = escenarios, type = "response")
resultado <- cbind(
Escenario     = c("Candidata fuerte", "Candidata dГ©bil", "Candidata media"),
escenarios,
P_Licencia    = round(probabilidades, 4),
Clasificacion = ifelse(probabilidades >= 0.5, "CONCEDIDA", "DENEGADA")
)
cat("\nв”Ђв”Ђ SimulaciГіn de escenarios в”Ђв”Ђ\n")
print(resultado[, c("Escenario", "SOLVENCIA", "IPUNT", "TINCID", "EFLO",
"P_Licencia", "Clasificacion")])
# Tabla formateada
kable_rstars(resultado[, c("Escenario", "SOLVENCIA", "IPUNT", "TINCID",
"EFLO", "P_Licencia", "Clasificacion")],
caption = "SimulaciГіn de escenarios: probabilidad de licencia",
digits  = 4)
cat("\nв•ђв•ђв•ђв•ђв•ђв•ђ TESTS COMPLETADOS в•ђв•ђв•ђв•ђв•ђв•ђ\n")
remotes::install_github("teckel71/MATrstars", force = TRUE)
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# MODELO LOGIT BINOMIAL вЂ” Licencias de operaciГіn en la ruta CoruscantвЂ“Arrakis
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# Script de prГЎctica del capГ­tulo 10 del libro R-Stars.
#
# Objetivo: modelizar quГ© factores determinan que la Autoridad GalГЎctica de
# Transporte Interestelar (AGTI) conceda o deniegue una licencia de operaciГіn
# a las compaГ±Г­as del sector que solicitan operar en una ruta intergalГЎctica.
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# Limpiando el Environment de objetos
rm(list = ls())
# Cargando paquetes
library(readxl)
library(dplyr)
library(ggplot2)
library(aod)       # Para el contraste de Wald sobre factores
library(MATrstars)
LICENCIAS <- read_excel("licencias_100.xlsx", sheet = "Datos")
LICENCIAS <- as.data.frame(LICENCIAS, row.names = 1)
summary(LICENCIAS)
str(LICENCIAS)
LICENCIAS$EFLO <- factor(LICENCIAS$EFLO,
levels = c("ANTIGUA", "MADURA", "RENOVADA"))
LICENCIAS$LICENCIA <- factor(LICENCIAS$LICENCIA)
# Verificamos la conversiГіn y la codificaciГіn de contrastes
is.factor(LICENCIAS$EFLO)
is.factor(LICENCIAS$LICENCIA)
contrasts(LICENCIAS$EFLO)
contrasts(LICENCIAS$LICENCIA)
# DistribuciГіn de la variable dependiente
table(LICENCIAS$LICENCIA)
# Tabla cruzada: LICENCIA por EFLO
table(LICENCIAS$EFLO, LICENCIAS$LICENCIA)
# Medias de las variables mГ©tricas segГєn LICENCIA
LICENCIAS %>%
group_by(LICENCIA) %>%
summarise(across(c(SOLVENCIA, IPUNT, TINCID, IFIDE, FLOTA, RUTAS, EXPERIENCIA),
~ round(mean(.), 2))) %>%
kable_rstars(caption = "Medias por grupo de licencia",
col.names = c("LICENCIA", "SOLVENCIA", "IPUNT", "TINCID",
"IFIDE", "FLOTA", "RUTAS", "EXPERIENCIA"))
ESTIMA <- LICENCIAS[1:80, ]
TEST   <- LICENCIAS[81:100, ]
cat("Muestra de estimaciГіn:", nrow(ESTIMA), "observaciones\n")
cat("Muestra de test:",       nrow(TEST),   "observaciones\n")
table(ESTIMA$LICENCIA)
table(TEST$LICENCIA)
modelo <- glm(LICENCIA ~ SOLVENCIA + IPUNT + TINCID + IFIDE +
FLOTA + RUTAS + EXPERIENCIA + EFLO,
data   = ESTIMA,
family = binomial(link = "logit"))
summary(modelo)
salida <- presenta_logit(modelo, datos = ESTIMA)
salida$coef    # Tabla 1: Coeficientes del modelo
salida$gof     # Tabla 2: Bondad del ajuste
salida$or      # Tabla 3: Odd ratios
# Identificamos quГ© posiciones del vector de coeficientes corresponden a EFLO.
# (Intercept)=1, SOLVENCIA=2, IPUNT=3, TINCID=4, IFIDE=5,
# FLOTA=6, RUTAS=7, EXPERIENCIA=8, EFLOMADURA=9, EFLORENOVADA=10
names(coef(modelo))
wald.test(b     = coef(modelo),
Sigma = vcov(modelo),
Terms = 9:10)
salida$or
salida$gof
anova(modelo, test = "Chisq")
modelo_nulo <- glm(LICENCIA ~ 1, data = ESTIMA,
family = binomial(link = "logit"))
AIC(modelo_nulo, modelo)
salida$conf
salida_test <- presenta_logit(modelo, datos = TEST,
captions = c("Modelo Logit Binomial",
"Bondad del ajuste",
"Odd ratios",
"Matriz de confusiГіn (TEST)"))
salida_test$conf
simulacion <- predict_from_excel_scenarios(
model      = modelo,
train_df   = ESTIMA,
excel_path = "escenarios_logit_rstars.xlsx",
sheet      = "Escenarios",
id_col     = "ESCENARIO",
umbral     = 0.5,
caption    = "SimulaciГіn de escenarios"
)
simulacion$table    # Tabla formateada con probabilidades y clasificaciГіn
simulacion$data     # Data frame con los resultados numГ©ricos
modelo_step <- step(modelo)
summary(modelo_step)
# PresentaciГіn del modelo reducido
salida_red <- presenta_logit(modelo_step, datos = ESTIMA,
captions = c("Modelo reducido (step)",
"Bondad del ajuste",
"Odd ratios",
"Matriz de confusiГіn"))
salida_red$coef
salida_red$gof
salida_red$or
salida_red$conf
# PredicciГіn del modelo reducido sobre la muestra de test
salida_red_test <- presenta_logit(modelo_step, datos = TEST,
captions = c("Modelo reducido",
"Bondad del ajuste",
"Odd ratios",
"ConfusiГіn TEST (reducido)"))
salida_red_test$conf
# ComparaciГіn de AIC: modelo completo vs. modelo reducido
AIC(modelo, modelo_step)

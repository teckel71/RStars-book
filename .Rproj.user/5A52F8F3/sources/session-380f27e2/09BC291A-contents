  library (kableExtra)
  knitr.table.format = "html" 

  tablamedias <-  muestra_so %>%
                    group_by(DIMENSION) %>%
                    summarise (observaciones = length(DIMENSION),
                               media = mean(RENECO))

  tablamedias %>%
    kable(format = knitr.table.format,

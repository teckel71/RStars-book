  out_cols <- lapply(seq_along(dn), function(k) {
    if (!is.null(dn[[k]])) dn[[k]][ idx[[k]] ] else idx[[k]]
  })
  names(out_cols) <- dn_names
  out <- as.data.frame(out_cols, stringsAsFactors = FALSE)
  out$Frecuencia_Original <- 0L
  out
}


        "  AIC=59.36\n~GALAXIA + EFLO + FJUR + GALAXIA:FJUR\n\n               Df    AIC\n<none>            59.359\n- GALAXIA:FJUR  8 59.670\n- EFLO          2 92.219\n",
        "> ",
        "generar_solucion(modelo_def)",
        "> ",
        "generar_solucion(modelo_def)",
        "> ",
        "solucion_modelo_def$Informacion",
